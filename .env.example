# ─── AeroSLS Navigator — AI Backend Configuration ────────────────────────────
#
# AI_BACKEND selects the inference engine.  Default: ollama (fully local).
#
#   ollama   — local Ollama daemon.  No data leaves your machine.
#              Install: https://ollama.com  then  ollama pull llama3.2
#   claude   — Anthropic Claude API.  Requires ANTHROPIC_API_KEY.
#   openai   — Any OpenAI-compatible server (LM Studio, llama.cpp, vLLM, etc.)
#
AI_BACKEND=ollama

# Model name.  Defaults per backend: ollama=llama3.2  claude=claude-opus-4-5
AI_MODEL=llama3.2

# ── Ollama (local, default) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── OpenAI-compatible (LM Studio / llama.cpp / vLLM / Ollama /v1/ mode) ──────
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=local   # can be any string for local servers

# ─── App URL (injected by hosting platform at runtime) ────────────────────────
APP_URL="MY_APP_URL"

